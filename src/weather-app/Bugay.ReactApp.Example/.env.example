# Container runtime env vars — used by entrypoint.sh to generate /config.json.
# For local Docker runs: docker run -e KEYCLOAK_URL=... -e ...
KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_REALM=master
KEYCLOAK_CLIENT_ID=react-app
API_BASE_URL=http://localhost:5000

# For local Vite dev (npm run dev), create public/config.json:
# {
#   "keycloakUrl": "http://localhost:8080",
#   "keycloakRealm": "master",
#   "keycloakClientId": "react-app",
#   "apiBaseUrl": "http://localhost:5000"
# }
